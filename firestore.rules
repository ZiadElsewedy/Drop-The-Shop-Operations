rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // The signed-in user's own document — their role/branch live here. Firestore
    // caches this get() per request, so repeated calls bill a single read.
    function selfDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function selfRole()   { return isSignedIn() ? selfDoc().get('role', 'employee') : 'none'; }
    function selfBranch() { return selfDoc().get('branchId', ''); }

    function isAdmin()   { return isSignedIn() && selfRole() == 'admin'; }
    function isManager() { return isSignedIn() && selfRole() == 'manager'; }

    // Branch scoping. Admin is global (any branch); a manager reaches only their
    // own branch. Employees never reach a whole branch — only their own data.
    function canReachBranch(branch) {
      return isAdmin() || (isManager() && branch == selfBranch());
    }

    // ── Users ──────────────────────────────────────────────────────
    // Self: read own doc + limited self-update (cannot touch privileged fields).
    // Manager: read employees in their own branch + any pending (unassigned)
    //   newcomer awaiting approval.
    // Admin: read/write everything — approvals, promotions, branch moves,
    //   (de)activation.
    match /users/{uid} {
      allow read: if isOwner(uid)
        || isAdmin()
        || (isManager()
            && (resource.data.get('branchId', '') == selfBranch()
                || resource.data.get('approvalStatus', 'approved') == 'pending'));

      // Self-registration only — always as a PENDING, INACTIVE employee. A new
      // account cannot use the app until it is approved (update rule below).
      // Promotion to manager/admin, branch assignment and activation are never
      // self-service.
      allow create: if isOwner(uid)
        && request.resource.data.get('role', 'employee') == 'employee'
        && request.resource.data.get('isActive', false) == false
        && request.resource.data.get('approvalStatus', 'pending') == 'pending';

      // Admin: full control — approve/reject, promote, move branch, (de)activate.
      // Manager: may approve/manage EMPLOYEES of their OWN branch only. They can
      //   flip approvalStatus / isActive / assignedShift and claim a pending
      //   newcomer into their branch, but can NEVER elevate role or assign a
      //   different branch (request.role must stay employee + request.branch must
      //   be their own; the target must already be in their branch OR be a
      //   pending employee newcomer).
      // Self: profile-only updates — all privileged fields stay frozen.
      allow update: if isAdmin()
        || (isManager()
            && request.resource.data.get('role', 'employee') == 'employee'
            && request.resource.data.get('branchId', '') == selfBranch()
            && (resource.data.get('branchId', '') == selfBranch()
                || (resource.data.get('approvalStatus', 'approved') == 'pending'
                    && resource.data.get('role', 'employee') == 'employee')))
        || (isOwner(uid)
            && request.resource.data.get('role', 'employee')
                 == resource.data.get('role', 'employee')
            && request.resource.data.get('isActive', true)
                 == resource.data.get('isActive', true)
            && request.resource.data.get('branchId', '')
                 == resource.data.get('branchId', '')
            && request.resource.data.get('assignedShift', '')
                 == resource.data.get('assignedShift', '')
            && request.resource.data.get('approvalStatus', 'approved')
                 == resource.data.get('approvalStatus', 'approved'));

      // Deactivate via isActive (an admin/manager update), never a hard delete;
      // document cleanup on account removal belongs to a Cloud Function.
      allow delete: if false;
    }

    // ── Branch-scoped collections (Phase 2+) ───────────────────────
    // Branches, shifts and tasks all carry a `branchId` and follow the same
    // model: admin global, manager own-branch, employee own data. Plug each new
    // collection in with the canReachBranch() helper, e.g.:
    //
    //   match /tasks/{taskId} {
    //     allow read:          if canReachBranch(resource.data.branchId)
    //                             || resource.data.assignedTo == request.auth.uid;
    //     allow create:        if canReachBranch(request.resource.data.branchId);
    //     allow update, delete: if canReachBranch(resource.data.branchId);
    //   }
  }
}
