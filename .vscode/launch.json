{
  // Named per-environment launch profiles. Each injects a committed config file
  // via --dart-define-from-file, so switching Local / Staging / Production never
  // requires editing source. Add more profiles by pointing at another config/*.json.
  "version": "0.2.0",
  "configurations": [
    {
      "name": "DROP Local",
      "request": "launch",
      "type": "dart",
      "toolArgs": ["--dart-define-from-file", "config/local.json"]
    },
    {
      "name": "DROP Staging",
      "request": "launch",
      "type": "dart",
      "toolArgs": ["--dart-define-from-file", "config/staging.json"]
    },
    {
      "name": "DROP Production",
      "request": "launch",
      "type": "dart",
      "toolArgs": ["--dart-define-from-file", "config/production.json"]
    },
    {
      "name": "DROP Production (release mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release",
      "toolArgs": ["--dart-define-from-file", "config/production.json"]
    }
  ]
}
